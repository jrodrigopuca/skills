#!/usr/bin/env bash
#
# ccinit - Inicializa el directorio .context en el proyecto actual
# Usage: ccinit
#

set -e

CONTEXT_DIR=".context"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Obtener directorio de trabajo (donde estamos parado)
WORKDIR="${1:-$(pwd)}"

echo -e "${YELLOW}Inicializando contexto en: ${WORKDIR}${NC}"

# Crear estructura de directorios
mkdir -p "${WORKDIR}/${CONTEXT_DIR}/decisions"
mkdir -p "${WORKDIR}/${CONTEXT_DIR}/steps"
mkdir -p "${WORKDIR}/${CONTEXT_DIR}/context"

# Crear .gitkeep para que se mantenga en git
touch "${WORKDIR}/${CONTEXT_DIR}/.gitkeep"
touch "${WORKDIR}/${CONTEXT_DIR}/decisions/.gitkeep"
touch "${WORKDIR}/${CONTEXT_DIR}/steps/.gitkeep"
touch "${WORKDIR}/${CONTEXT_DIR}/context/.gitkeep"

# Crear README si no existe
if [ ! -f "${WORKDIR}/${CONTEXT_DIR}/README.md" ]; then
  cat > "${WORKDIR}/${CONTEXT_DIR}/README.md" << 'EOF'
# Contexto Compactado

Directorio para guardar decisiones, pasos y contexto importante del proyecto.

## Estructura

```
.context/
├── decisions/   # Decisiones importantes con su contexto
├── steps/       # Procesos y procedimientos
└── context/     # Estado general y información
```

## Comandos

```bash
ccsave "título" "contenido"     # Guardar rápido
ccnote "título"                 # Crear nota con template
cclist                          # Listar notas
ccgrep "patrón"                 # Buscar en notas
```

## Tips

- Sé específico con los títulos
- Incluye el "por qué" en las decisiones
- Actualiza cuando el contexto cambie
EOF
fi

echo -e "${GREEN}✓${NC} Directorio ${CONTEXT_DIR} creado en ${WORKDIR}"
echo ""
echo "Estructura:"
echo "  .context/"
echo "  ├── decisions/"
echo "  ├── steps/"
echo "  └── context/"
echo ""
echo "Para usar desde cualquier lugar, agregá alias a tu ~/.zshrc:"
echo '  alias ccinit="~/scripts/context-compactor/ccinit"'
echo '  alias ccsave="~/scripts/context-compactor/ccsave"'
echo '  alias ccnote="~/scripts/context-compactor/ccnote"'
echo '  alias cclist="~/scripts/context-compactor/cclist"'
echo '  alias ccgrep="~/scripts/context-compactor/ccgrep"'
