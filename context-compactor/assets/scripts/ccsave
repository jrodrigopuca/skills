#!/usr/bin/env bash
#
# ccsave - Quick context save without a full template
# Usage: ccsave "title" "content" [type]
#   type: decision|step|context (default: context)
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

# Working directory
WORKDIR="$(pwd)"
CONTEXT_DIR="${WORKDIR}/.context"

# Verify .context exists
if [ ! -d "${CONTEXT_DIR}" ]; then
  echo -e "${RED}Error: ${CONTEXT_DIR} does not exist${NC}"
  echo "Run ccinit first to initialize"
  exit 1
fi

# Arguments
TITLE="${1:-}"
CONTENT="${2:-}"
TYPE="${3:-context}"

# Normalize type
case "${TYPE}" in
  decision|d) TYPE="decision" ;;
  step|steps|s) TYPE="steps" ;;
  *) TYPE="context" ;;
esac

if [ -z "${TITLE}" ]; then
  echo "Usage: ccsave \"title\" \"content\" [type]"
  echo "  type: decision|step|context (default: context)"
  exit 1
fi

# Generate filename
DATE=$(date +%Y-%m-%d)
SLUG=$(echo "${TITLE}" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
FILENAME="${DATE}-${SLUG}.md"
case "${TYPE}" in
  decision) SUBDIR="decisions" ;;
  steps)    SUBDIR="steps" ;;
  *)        SUBDIR="context" ;;
esac
FILEPATH="${CONTEXT_DIR}/${SUBDIR}/${FILENAME}"

# Create file
cat > "${FILEPATH}" << EOF
# ${TITLE}

> Compacted at: $(date +%Y-%m-%d\ %H:%M:%S)
> Type: ${TYPE}

---

${CONTENT}

---

## Tags

#context #compacted #${TYPE}

EOF

echo -e "${GREEN}✓${NC} Saved to: ${FILEPATH}"
