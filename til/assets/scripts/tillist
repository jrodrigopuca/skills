#!/usr/bin/env bash
#
# tillist - List TIL notes, optionally filtered by topic
# Usage: tillist [topic]

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

TIL_DIR="${TIL_DIR:-$HOME/.til}"
TOPIC="${1:-}"

if [ ! -d "${TIL_DIR}" ]; then
  echo -e "${RED}No TIL base yet${NC} — save your first note with: til \"title\" \"content\" [topic]"
  exit 0
fi

list_topic() {
  local dir="$1"
  local topic
  topic=$(basename "${dir}")
  local count
  count=$(find "${dir}" -name "*.md" -type f | wc -l | tr -d ' ')
  [ "${count}" -eq 0 ] && return 0
  echo -e "\n${BLUE}# ${topic}${NC} (${count})"
  echo "────────────────────────────────"
  find "${dir}" -name "*.md" -type f | sort -r | while read -r file; do
    local title
    title=$(head -1 "${file}" | sed 's/^# //')
    local date
    date=$(basename "${file}" | cut -d'-' -f1,2,3)
    echo -e "  ${GREEN}${date}${NC} ${title}"
  done
}

echo -e "${YELLOW}TIL base: ${TIL_DIR}${NC}"

if [ -n "${TOPIC}" ]; then
  if [ -d "${TIL_DIR}/${TOPIC}" ]; then
    list_topic "${TIL_DIR}/${TOPIC}"
  else
    echo -e "${RED}No notes for topic '${TOPIC}'${NC}"
    exit 0
  fi
else
  find "${TIL_DIR}" -mindepth 1 -maxdepth 1 -type d | sort | while read -r dir; do
    list_topic "${dir}"
  done
fi

echo ""
if [ -n "${TOPIC}" ] && [ -d "${TIL_DIR}/${TOPIC}" ]; then
  echo -e "Total in '${TOPIC}': $(find "${TIL_DIR}/${TOPIC}" -name "*.md" -type f | wc -l | tr -d ' ') notes"
else
  echo -e "Total: $(find "${TIL_DIR}" -name "*.md" -type f | wc -l | tr -d ' ') notes"
fi
