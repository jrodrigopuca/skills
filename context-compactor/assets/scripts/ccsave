#!/usr/bin/env bash
#
# ccsave - Guarda contexto rápido sin template
# Usage: ccsave "título" "contenido" [tipo]
#   tipo: decision|step|context (default: context)
#

set -e

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Obtener directorio de trabajo
WORKDIR="${3:-$(pwd)}"
CONTEXT_DIR="${WORKDIR}/.context"

# Verificar que existe .context
if [ ! -d "${CONTEXT_DIR}" ]; then
  echo -e "${RED}Error: ${CONTEXT_DIR} no existe${NC}"
  echo "Ejecutá ccinit primero para inicializar"
  exit 1
fi

# Argumentos
TITLE="${1:-}"
CONTENT="${2:-}"
TYPE="${3:-context}"

# Normalizar tipo
case "${TYPE}" in
  decision|d) TYPE="decision" ;;
  decision) TYPE="decision" ;;
  step|s) TYPE="steps" ;;
  steps) TYPE="steps" ;;
  *) TYPE="context" ;;
esac

# Si el tercer arg es un path válido, reasignar
if [ -d "$3" ]; then
  CONTEXT_DIR="$3/.context"
  TYPE="${4:-context}"
fi

if [ -z "${TITLE}" ]; then
  echo "Usage: ccsave \"título\" \"contenido\" [tipo]"
  echo "  tipo: decision|step|context (default: context)"
  exit 1
fi

# Generar nombre de archivo
DATE=$(date +%Y-%m-%d)
SLUG=$(echo "${TITLE}" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
FILENAME="${DATE}-${SLUG}.md"
FILEPATH="${CONTEXT_DIR}/${TYPE}s/${FILENAME}"

# Crear archivo
cat > "${FILEPATH}" << EOF
# ${TITLE}

> Compactado el: $(date +%Y-%m-%d\ %H:%M:%S)
> Tipo: ${TYPE}

---

${CONTENT}

---

## Tags

#context #compacted #${TYPE}

EOF

echo -e "${GREEN}✓${NC} Guardado en: ${FILEPATH}"
