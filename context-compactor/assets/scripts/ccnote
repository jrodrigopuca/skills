#!/usr/bin/env bash
#
# ccnote - Create a note from a full template
# Usage: ccnote "title" [type]
#   type: decision|step|context (default: context)
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Working directory
WORKDIR="$(pwd)"
CONTEXT_DIR="${WORKDIR}/.context"

# Verify .context exists
if [ ! -d "${CONTEXT_DIR}" ]; then
  echo -e "${RED}Error: ${CONTEXT_DIR} does not exist${NC}"
  echo "Run ccinit first to initialize"
  exit 1
fi

# Arguments
TITLE="${1:-}"
TYPE="${2:-context}"

# Normalize type
case "${TYPE}" in
  decision|d) TYPE="decision" ;;
  step|steps|s) TYPE="steps" ;;
  *) TYPE="context" ;;
esac

if [ -z "${TITLE}" ]; then
  echo "Usage: ccnote \"title\" [type]"
  echo "  type: decision|step|context (default: context)"
  exit 1
fi

# Generate filename
DATE=$(date +%Y-%m-%d)
SLUG=$(echo "${TITLE}" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
FILENAME="${DATE}-${SLUG}.md"
case "${TYPE}" in
  decision) SUBDIR="decisions" ;;
  steps)    SUBDIR="steps" ;;
  *)        SUBDIR="context" ;;
esac
FILEPATH="${CONTEXT_DIR}/${SUBDIR}/${FILENAME}"

# Template per type
case "${TYPE}" in
  decision)
    cat > "${FILEPATH}" << EOF
# Decision: ${TITLE}

> Date: $(date +%Y-%m-%d\ %H:%M:%S)

## Context
{Why was this decision made? What problem does it solve?}

## Options considered
- **Option A**: {description}
  - Pros:
  - Cons:
- **Option B**: {description}
  - Pros:
  - Cons:

## Final decision
{What was chosen and why?}

## Consequences
- **Positive**:
- **Negative/Trade-offs**:

## Status
- [ ] Pending validation
- [ ] Implemented
- [ ] Reviewed

## Tags

#context #decision #${SLUG}

---
*Created with ccnote*
EOF
    ;;
  steps)
    cat > "${FILEPATH}" << EOF
# Steps: ${TITLE}

> Date: $(date +%Y-%m-%d\ %H:%M:%S)

## Goal
{What does this process achieve?}

## Prerequisites
-

## Step 1: {title}
**Action**: {what to do}
**Expected result**:

## Step 2: {title}
**Action**: {what to do}
**Expected result**:

## Step 3: {title}
**Action**: {what to do}
**Expected result**:

## Verification
{How to confirm it worked}

## Troubleshooting
- **Problem**:
  - **Solution**:

## Tags

#context #steps #${SLUG}

---
*Created with ccnote*
EOF
    ;;
  context|*)
    cat > "${FILEPATH}" << EOF
# Context: ${TITLE}

> Date: $(date +%Y-%m-%d\ %H:%M:%S)

## Current state
{What is happening right now?}

## Key information
- Point 1
- Point 2
- Point 3

## Open questions
- [ ] {question 1}
- [ ] {question 2}

## Next steps
- [ ] {pending action}
- [ ] {completed action}

## References
-

## Tags

#context #${SLUG}

---
*Created with ccnote*
EOF
    ;;
esac

echo -e "${GREEN}✓${NC} Created: ${FILEPATH}"
echo ""
echo "Type: ${TYPE}"
echo ""
# Suggest opening in editor if available
if command -v code &> /dev/null; then
  echo -e "${YELLOW}Want to open it?${NC} Run 'code ${FILEPATH}'"
fi
