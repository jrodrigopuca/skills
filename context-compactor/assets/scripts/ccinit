#!/usr/bin/env bash
#
# ccinit - Initialize the .context directory in the current project
# Usage: ccinit
#

set -e

CONTEXT_DIR=".context"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Working directory (where we are standing)
WORKDIR="${1:-$(pwd)}"

echo -e "${YELLOW}Initializing context in: ${WORKDIR}${NC}"

# Create directory structure
mkdir -p "${WORKDIR}/${CONTEXT_DIR}/decisions"
mkdir -p "${WORKDIR}/${CONTEXT_DIR}/steps"
mkdir -p "${WORKDIR}/${CONTEXT_DIR}/context"

# Create .gitkeep files so git keeps the directories
touch "${WORKDIR}/${CONTEXT_DIR}/.gitkeep"
touch "${WORKDIR}/${CONTEXT_DIR}/decisions/.gitkeep"
touch "${WORKDIR}/${CONTEXT_DIR}/steps/.gitkeep"
touch "${WORKDIR}/${CONTEXT_DIR}/context/.gitkeep"

# Create README if it does not exist
if [ ! -f "${WORKDIR}/${CONTEXT_DIR}/README.md" ]; then
  cat > "${WORKDIR}/${CONTEXT_DIR}/README.md" << 'EOF'
# Compacted Context

Directory for saving important project decisions, steps, and context.

## Structure

```
.context/
├── decisions/   # Important decisions with their context
├── steps/       # Processes and procedures
└── context/     # General state and information
```

## Commands

```bash
ccsave "title" "content"     # Quick save
ccnote "title"               # Create note from template
cclist                       # List notes
ccgrep "pattern"             # Search notes
```

## Tips

- Be specific with titles
- Include the "why" in decisions
- Update notes when the context changes
EOF
fi

echo -e "${GREEN}✓${NC} ${CONTEXT_DIR} directory created in ${WORKDIR}"
echo ""
echo "Structure:"
echo "  .context/"
echo "  ├── decisions/"
echo "  ├── steps/"
echo "  └── context/"
echo ""
echo "To use from anywhere, add aliases to your ~/.zshrc:"
echo '  alias ccinit="~/.local/bin/ccinit"'
echo '  alias ccsave="~/.local/bin/ccsave"'
echo '  alias ccnote="~/.local/bin/ccnote"'
echo '  alias cclist="~/.local/bin/cclist"'
echo '  alias ccgrep="~/.local/bin/ccgrep"'
