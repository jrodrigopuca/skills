#!/usr/bin/env bash
#
# ccgrep - Busca en notas guardadas
# Usage: ccgrep "patrón"
#

set -e

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Obtener directorio de trabajo
WORKDIR="$(pwd)"
CONTEXT_DIR="${WORKDIR}/.context"

# Verificar que existe .context
if [ ! -d "${CONTEXT_DIR}" ]; then
  echo -e "${RED}Error: ${CONTEXT_DIR} no existe${NC}"
  echo "Ejecutá ccinit primero para inicializar"
  exit 1
fi

PATTERN="${1:-}"

if [ -z "${PATTERN}" ]; then
  echo "Usage: ccgrep \"patrón\""
  exit 1
fi

echo -e "${YELLOW}Buscando: ${PATTERN}${NC}"
echo ""

# Buscar en todos los archivos markdown
RESULTS=$(rg -l -i "${PATTERN}" "${CONTEXT_DIR}" --glob "*.md" --glob "!.gitkeep" 2>/dev/null || true)

if [ -z "${RESULTS}" ]; then
  echo -e "${RED}No se encontraron resultados${NC}"
  exit 0
fi

# Mostrar resultados con contexto
echo "${RESULTS}" | while read -r file; do
  local filename=$(basename "${file}")
  local title=$(head -1 "${file}" | sed 's/^# //')
  
  echo -e "${BLUE}# ${title}${NC}"
  echo -e "  ${GREEN}${file}${NC}"
  echo ""
  
  rg -i -n "${PATTERN}" "${file}" --glob "*.md" | head -3 | while read -r line; do
    echo "  ${line}"
  done
  echo ""
  echo "────────────────────────────────"
  echo ""
done
